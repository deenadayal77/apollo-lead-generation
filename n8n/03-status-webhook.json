      "parameters": {
        "jsCode": "const jobMeta = $('Find Job Record').first().json;\nconst jobId    = jobMeta._jobId         || '';\nconst allRows  = $input.all();\n\nconst companyRows = allRows.filter(item => item.json.jobId === jobId);\n\nconst companies = companyRows.map(item => {\n  const r = item.json;\n  return {\n    company_linkedin_url: r.company_linkedin_url || '',\n    company_name:         r.company_name         || '',\n    status:               r.status               || 'pending',\n    person_name:          r.person_name          || undefined,\n    title:                r.title                || undefined,\n    seniority:            r.seniority            || undefined,\n    email:                r.email                || undefined,\n    phone:                r.phone                || undefined,\n    location:             r.location             || undefined,\n    industry:             r.industry             || undefined,\n    company_size:         r.company_size         || undefined,\n    reason:               r.reason               || undefined,\n    enriched_at:          r.enriched_at          || undefined\n  };\n});\n\nconst jobStatus    = jobMeta.jobStatus      || 'pending';\nconst totalCompanies = jobMeta.totalCompanies || companies.length;\nconst processedCount = jobMeta.processedCount || companies.length;\n\nconst responseBody = {\n  jobId,\n  status:           jobStatus,\n  totalCompanies:   Number(totalCompanies),\n  processedCount:   jobStatus === 'complete' ? Number(totalCompanies) : Number(processedCount),\n  companies,\n  createdAt:        jobMeta.createdAt  || '',\n  updatedAt:        jobMeta.updatedAt  || new Date().toISOString()\n};\n\nreturn [{ json: responseBody }];"
