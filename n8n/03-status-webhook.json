        "jsCode": "const jobId = $('Parse Query Params').first().json.jobId || '';\nconst items = $input.all();\n\nconst jobRow = items.find(item => item.json.jobId === jobId);\n\nif (!jobRow) {\n  return [{ json: {\n    _not_found: true,\n    _jobId: jobId\n  }}];\n}\n\nreturn [{ json: {\n  _found: true,\n  _jobId: jobId,\n  jobStatus:      jobRow.json.status         || 'pending',\n  totalCompanies: Number(jobRow.json.totalCompanies || 0),\n  processedCount: Number(jobRow.json.processedCount || 0),\n  createdAt:      jobRow.json.createdAt      || '',\n  updatedAt:      jobRow.json.updatedAt      || ''\n}}];"
